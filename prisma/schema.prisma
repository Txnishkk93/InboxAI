generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Provider {
  google
  outlook
  other
}

enum WorkspaceRole {
  owner
  admin
  member
  viewer
}

enum DnsScanStatus {
  running
  complete
  failed
}

enum DnsCheckType {
  spf
  dkim
  dmarc
  mx
  bimi
  alignment
}

enum DnsCheckStatus {
  pass
  warn
  fail
}

enum RecommendationSeverity {
  low
  medium
  high
  critical
}

enum RecommendationStatus {
  open
  resolved
  dismissed
}

enum PlacementResult {
  inbox
  promotions
  spam
  missing
  pending
}

enum SeedInboxProvider {
  gmail
  outlook
  yahoo
  custom
}

enum AlertType {
  score_drop
  placement_drop
  dns_check_failed
}

enum AlertChannel {
  email
  slack
}

enum AlertStatus {
  pending
  sent
  failed
}

model User {
  id           String   @id @default(cuid())
  clerkUserId  String   @unique
  email        String?
  name         String?
  createdAt    DateTime @default(now())
  memberships  WorkspaceMembership[]

  @@map("users")
}

model Workspace {
  id                String   @id @default(cuid())
  name              String
  createdAt         DateTime @default(now())
  ownerId           String
  slackWebhookUrl   String?
  alertEmail        String?
  memberships       WorkspaceMembership[]
  domains           Domain[]
  mailboxes         Mailbox[]
  alerts            Alert[]

  @@map("workspaces")
}

model WorkspaceMembership {
  id           String         @id @default(cuid())
  userId       String
  workspaceId  String
  role         WorkspaceRole
  createdAt    DateTime       @default(now())
  user         User           @relation(fields: [userId], references: [id])
  workspace    Workspace      @relation(fields: [workspaceId], references: [id])

  @@unique([userId, workspaceId])
  @@map("workspace_memberships")
}

model Domain {
  id           String    @id @default(cuid())
  workspaceId  String
  domainName   String
  createdAt    DateTime  @default(now())
  status       String    @default("active")
  deletedAt    DateTime?
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  mailboxes    Mailbox[]
  alerts       Alert[]

  @@map("domains")
}

model Mailbox {
  id           String    @id @default(cuid())
  workspaceId  String
  domainId     String
  senderEmail  String
  provider     Provider
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  domain       Domain    @relation(fields: [domainId], references: [id])

  @@map("mailboxes")
}

model DnsScan {
  id            String          @id @default(cuid())
  workspaceId    String
  domainId       String
  triggeredBy    String          @default("manual")
  status         DnsScanStatus   @default(running)
  startedAt      DateTime        @default(now())
  completedAt    DateTime?
  checks         DnsScanCheck[]

  @@map("dns_scans")
}

model DnsScanCheck {
  id           String         @id @default(cuid())
  dnsScanId    String
  checkType    DnsCheckType
  status       DnsCheckStatus
  rawValue     String?
  parsedDetail Json?
  createdAt    DateTime       @default(now())
  dnsScan      DnsScan        @relation(fields: [dnsScanId], references: [id])

  @@map("dns_scan_checks")
}

model ScoreHistory {
  id              String   @id @default(cuid())
  workspaceId     String
  domainId        String
  scoreVersion    String
  totalScore      Int
  scoreBreakdown  Json
  rawSignals      Json
  calculatedAt    DateTime @default(now())

  @@map("score_history")
}

model Recommendation {
  id            String                  @id @default(cuid())
  workspaceId   String
  domainId      String
  title         String
  description   String
  severity      RecommendationSeverity
  confidence    Int
  category      String
  status        RecommendationStatus   @default(open)
  createdAt     DateTime                @default(now())
  resolvedAt    DateTime?
  relatedCheckIds Json?

  @@map("recommendations")
}

model SeedInbox {
  id            String              @id @default(cuid())
  provider      SeedInboxProvider
  emailAddress  String
  credentialsRef String
  isActive      Boolean             @default(true)
  createdAt     DateTime            @default(now())

  @@map("seed_inboxes")
}

model PlacementTest {
  id                  String           @id @default(cuid())
  workspaceId         String
  domainId            String
  mailboxId           String
  testBatchId         String
  provider            SeedInboxProvider
  subjectFingerprint  String
  bodyFingerprint     String
  sentAt              DateTime         @default(now())
  result              PlacementResult  @default(pending)
  resultDetectedAt    DateTime?
  folderRaw           String?

  @@map("placement_tests")
}

model Alert {
  id           String       @id @default(cuid())
  workspaceId  String
  domainId     String
  type         AlertType
  severity     String
  message      String
  triggeredAt  DateTime     @default(now())
  channel      AlertChannel @default(email)
  deliveredAt  DateTime?
  status       AlertStatus  @default(pending)
  dedupeKey    String
  createdAt    DateTime     @default(now())
  workspace    Workspace    @relation(fields: [workspaceId], references: [id])
  domain       Domain       @relation(fields: [domainId], references: [id])

  @@map("alerts")
}

model ProviderProfile {
  id                    String   @id @default(cuid())
  provider              String
  notes                 String?
  activeSeedInboxCount Int      @default(0)
  createdAt             DateTime @default(now())

  @@map("provider_profiles")
}
